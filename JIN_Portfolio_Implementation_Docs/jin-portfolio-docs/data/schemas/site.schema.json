{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/site.schema.json",
  "title": "Portfolio Site Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["siteName", "baseUrl", "defaultLocale", "locales", "navigation", "socials", "features"],
  "properties": {
    "$schema": {"type": "string"},
    "siteName": {"type": "string", "minLength": 1},
    "baseUrl": {"type": "string", "format": "uri"},
    "defaultLocale": {"enum": ["en", "vi"]},
    "locales": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"enum": ["en", "vi"]}
    },
    "navigation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "href"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "href": {"type": "string", "pattern": "^/"}
        }
      }
    },
    "socials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "url"],
        "properties": {
          "type": {"enum": ["github", "linkedin", "zalo", "other"]},
          "url": {"type": "string", "format": "uri"}
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analytics", "contactForm", "notes", "themeToggle"],
      "properties": {
        "analytics": {"type": "boolean"},
        "contactForm": {"type": "boolean"},
        "notes": {"type": "boolean"},
        "themeToggle": {"type": "boolean"}
      }
    }
  }
}
